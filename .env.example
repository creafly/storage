# ===========================================
# Storage Service Configuration
# ===========================================

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8083
GIN_MODE=debug  # Use 'release' in production

# Database (REQUIRED)
DATABASE_URL=postgres://storage:password@localhost:5435/storage?sslmode=disable
AUTO_MIGRATE=true

# MinIO Configuration (REQUIRED)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=hexaend-storage

# File Upload Limits
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/png,image/svg+xml,image/jpeg,image/webp,image/gif
ALLOWED_DOCUMENT_TYPES=application/pdf

# Identity Service (for centralized authentication)
IDENTITY_SERVICE_URL=http://localhost:8080

# CORS Configuration (required in production)
# Comma-separated list of allowed origins
# Leave empty for development (allows all origins)
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# Localization
DEFAULT_LOCALE=en-US

# Logging
LOG_LEVEL=info

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
OTLP_ENDPOINT=localhost:4317
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
