# ===========================================
# Storage Service Configuration
# ===========================================

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8083
GIN_MODE=debug  # Use 'release' in production

# ===========================================
# Vault Configuration (recommended for production)
# ===========================================
# When VAULT_ENABLED=true, secrets are loaded from Vault
# with fallback to environment variables.
# For local development without Vault, set VAULT_ENABLED=false
#
VAULT_ENABLED=false
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
# VAULT_MOUNT=secret
#
# Vault secrets path: creafly/{ENVIRONMENT}/storage
# Vault secrets:
#   - database_password
#   - minio_access_key
#   - minio_secret_key
#   - internal_api_key

# ===========================================
# Database Configuration
# ===========================================
# Connection parameters (non-sensitive)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=storage
DATABASE_USER=postgres
DATABASE_SSL_MODE=disable

# Password is loaded from Vault (database_password) or env:
DATABASE_PASSWORD=postgres

AUTO_MIGRATE=true

# ===========================================
# MinIO Configuration
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=creafly-storage

# ===========================================
# File Upload Limits
# ===========================================
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/png,image/svg+xml,image/jpeg,image/webp,image/gif
ALLOWED_DOCUMENT_TYPES=application/pdf,text/plain,text/markdown

# ===========================================
# Service URLs
# ===========================================
IDENTITY_SERVICE_URL=http://localhost:8080

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
# Leave empty for development (allows all origins)
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true

# ===========================================
# Kafka Configuration
# ===========================================
KAFKA_ENABLED=true
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=notifications-service

# ===========================================
# Outbox Configuration
# ===========================================
OUTBOX_ENABLED=true
OUTBOX_POLL_INTERVAL=1s
OUTBOX_BATCH_SIZE=100
OUTBOX_CLEANUP_INTERVAL=1h
OUTBOX_RETENTION_PERIOD=24h
OUTBOX_FAILED_RETENTION_PERIOD=168h

# ===========================================
# Other Settings
# ===========================================
DEFAULT_LOCALE=en-US
LOG_LEVEL=info

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
OTLP_ENDPOINT=localhost:4317
SERVICE_VERSION=1.0.0
ENVIRONMENT=development

# Loki (Centralized Logging)
LOKI_ENABLED=false
LOKI_URL=http://localhost:3100

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# Trusted proxy IPs for X-Forwarded-For parsing (comma-separated)
# Only these IPs are trusted to set X-Forwarded-For header
# Example: TRUSTED_PROXIES=10.0.0.1,10.0.0.2,192.168.1.1
TRUSTED_PROXIES=

# ===========================================
# Internal API Configuration
# ===========================================
# API key for service-to-service authentication
# INTERNAL_API_KEY is loaded from Vault (internal_api_key) or env
INTERNAL_API_KEY=

# Comma-separated list of allowed service names for internal endpoints
INTERNAL_ALLOWED_SERVICES=notifications,agent,subscriptions

# ===========================================
# DEPRECATED
# ===========================================
# DATABASE_URL is no longer used. Use individual components above.
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/storage?sslmode=disable
